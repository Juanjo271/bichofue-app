# CaliGuia Backend Environment Variables
# Copia este archivo a .env.local y rellena tus claves reales (NO commitees .env.local)

# OpenCode Go API Key
OPENCODE_GO_API_KEY=TU_OPENCODE_API_KEY_AQUI

# OpenCode Go Model
OPENCODE_GO_MODEL=qwen3.5-plus

# Ollama (IA local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma4:e4b
USE_LOCAL_LLM=true

# Mapbox API Key
MAPBOX_API_KEY=TU_MAPBOX_ACCESS_TOKEN_AQUI
